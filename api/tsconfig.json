{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "../api-dist",
    "noEmit": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["./**/*.test.ts"]
}
